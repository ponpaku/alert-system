location_name = "案内カウンターA"

[http]
user_agent = "ReceptionAlert/1.0"
request_timeout_seconds = 5
verify_tls = true
ca_bundle_path = ""
response_body_limit_bytes = 4096

[gpio]
alive_led_gpio = 5
send_led_gpio = 27

[timing]
bounce_seconds = 0.08
cooldown_seconds = 3
success_hold_seconds = 30
failure_blink_seconds = 30

[delivery]
retry_delays_seconds = [0, 1, 3]
queue_capacity = 8
shutdown_grace_seconds = 6
max_retry_after_seconds = 30
max_event_delivery_seconds = 15
running_cutoff_grace_seconds = 5.5
max_parallel_destinations = 4
persistent_queue_path = "reception-alert-queue.sqlite3"
persistent_retry_base_seconds = 15
persistent_retry_max_seconds = 300

[heartbeat]
enabled = false
url = "https://script.google.com/macros/s/DEPLOYMENT_ID/exec"
method = "POST"
interval_seconds = 300
timeout_seconds = 5
jitter_seconds = 15
failure_backoff_seconds = 60
stale_after_seconds = 900
send_on_startup = true
send_on_shutdown = true
include_queue_depth = true
include_worker_alive = true
shared_secret = "OPTIONAL_SHARED_SECRET"
instance_id = "frontdesk-a"

[[destinations]]
type = "nextcloud_talk"
# Unique destination ID referenced from buttons[].destinations.
# This is the routing key used by buttons.
name = "talk-main"
enabled = true
base_url = "https://cloud.example.com"
username = "alertbot"
app_password = "APP_PASSWORD"
room_token = "ROOM_TOKEN"

[[destinations]]
type = "nextcloud_bot"
# Unique destination ID referenced from buttons[].destinations.
name = "talk-bot-main"
enabled = false
base_url = "https://cloud.example.com"
conversation_token = "ROOM_TOKEN"
shared_secret = "SHARED_SECRET"
silent = false

[[destinations]]
type = "discord_webhook"
# Unique destination ID referenced from buttons[].destinations.
name = "discord-ops"
enabled = true
webhook_url = "https://discord.com/api/webhooks/..."

[[destinations]]
type = "slack_webhook"
# Unique destination ID referenced from buttons[].destinations.
name = "slack-frontdesk"
enabled = true
webhook_url = "https://hooks.slack.com/services/..."

[[destinations]]
type = "line_bot"
# Unique destination ID referenced from buttons[].destinations.
name = "line-main"
enabled = false
channel_access_token = "LINE_CHANNEL_ACCESS_TOKEN"
to = "USER_OR_GROUP_ID"

[[destinations]]
type = "generic_webhook"
# Unique destination ID referenced from buttons[].destinations.
name = "custom-hook"
enabled = true
url = "https://hooks.example.com/reception"
method = "POST"
content_type = "json"
success_status_codes = [200, 201, 202]

[destinations.auth]
type = "bearer"
token = "SECRET"

[destinations.headers]
X-Device = "frontdesk-a"

[destinations.payload]
event = "reception_alert"
event_id = "{{ event_id }}"
button = "{{ button_name }}"
message = "{{ message }}"
location = "{{ location_name }}"
text = "{{ text }}"

[[buttons]]
name = "staff"
gpio = 17
prefix = "【受付通知】"
message = "人手をお願いします"
# Route by destination.name values defined above.
destinations = ["talk-main", "discord-ops", "custom-hook"]

[[buttons]]
name = "urgent"
gpio = 22
prefix = "【受付至急】"
message = "すぐ来てください"
# Route by destination.name values defined above.
destinations = ["talk-main", "slack-frontdesk"]

[[buttons]]
name = "emergency"
gpio = 23
prefix = "【受付緊急】"
message = "至急応援をお願いします"
# Route by destination.name values defined above.
destinations = ["talk-main", "discord-ops", "slack-frontdesk"]
